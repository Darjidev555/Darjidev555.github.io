  </main>

  <script>
    // Mobile hamburger menu — slide-down panel, thumb-friendly
    const navToggle = document.getElementById('nav-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');
    if (navToggle && mobileMenu) {
      const setMenu = (open) => {
        mobileMenu.classList.toggle('is-open', open);
        navToggle.setAttribute('aria-expanded', String(open));
        navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        iconOpen.classList.toggle('hidden', open);
        iconClose.classList.toggle('hidden', !open);
      };
      navToggle.addEventListener('click', () => setMenu(!mobileMenu.classList.contains('is-open')));
      mobileMenu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
      addEventListener('resize', () => { if (window.innerWidth >= 768) setMenu(false); });
    }

    // Scroll-reveal — reveal generously ahead of the viewport, plus a safety
    // net so content can never stay hidden if the observer ever misses one.
    const els = document.querySelectorAll('.reveal');
    const showAll = () => els.forEach((el) => el.classList.add('is-in'));
    if ('IntersectionObserver' in window && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-in');
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: '0px 0px 600px 0px', threshold: 0 },
      );
      els.forEach((el) => io.observe(el));
      // Safety: anything still hidden after 2.5s gets shown unconditionally.
      window.setTimeout(showAll, 2500);
    } else {
      showAll();
    }

    // Header hairline appears once you scroll past the hero top
    const header = document.getElementById('site-header');
    const onScroll = () => {
      if (window.scrollY > 12) header?.classList.add('border-line/100', 'shadow-sm');
      else header?.classList.remove('border-line/100', 'shadow-sm');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // 3D pointer-tilt on project showcases (pointer devices only, motion-safe)
    const fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
    const noMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (fine && !noMotion) {
      document.querySelectorAll('.tilt-stage').forEach((stage) => {
        const card = stage.querySelector('.tilt');
        if (!card) return;
        const power = Number(card.getAttribute('data-tilt')) || 7;
        let frame = 0;
        stage.addEventListener('pointermove', (ev) => {
          if (frame) return;
          frame = requestAnimationFrame(() => {
            frame = 0;
            const r = stage.getBoundingClientRect();
            const dx = (ev.clientX - r.left) / r.width - 0.5;
            const dy = (ev.clientY - r.top) / r.height - 0.5;
            card.style.transform =
              'rotateY(' + (dx * power).toFixed(2) + 'deg) rotateX(' + (-dy * power).toFixed(2) + 'deg)';
          });
        });
        stage.addEventListener('pointerleave', () => {
          card.style.transform = '';
        });
      });
    }

    // Premium phone-deck — symmetric coverflow: active phone big in the
    // centre, neighbours peeking on the left AND right, turned inward.
    const coverLevels = [
      { x: 0, s: 1, ry: 0, o: 1, b: 0 }, // centre — big
      { x: 43, s: 0.8, ry: 26, o: 0.5, b: 1 }, // immediate neighbours
      { x: 69, s: 0.62, ry: 31, o: 0.22, b: 2 }, // further back
    ];
    document.querySelectorAll('[data-deck]').forEach((deck) => {
      const cards = Array.from(deck.querySelectorAll('.deck-card'));
      const dotWrap = deck.parentElement && deck.parentElement.querySelector('[data-dots]');
      const dots = dotWrap ? Array.from(dotWrap.querySelectorAll('.deck-dot')) : [];
      const total = cards.length;
      if (total <= 1) return;
      let active = 0;
      const place = () => {
        cards.forEach((card, idx) => {
          // signed offset so cards before active go left, after go right
          let off = idx - active;
          if (off > total / 2) off -= total;
          if (off < -total / 2) off += total;
          const dir = Math.sign(off);
          const lvl = Math.abs(off);
          const L = coverLevels[Math.min(lvl, coverLevels.length - 1)];
          const hidden = lvl >= coverLevels.length;
          card.style.transform =
            'translateX(' + dir * L.x + '%) scale(' + L.s + ') rotateY(' + -dir * L.ry + 'deg)';
          card.style.opacity = hidden ? '0' : String(L.o);
          card.style.filter = lvl === 0 ? 'none' : 'blur(' + L.b + 'px)';
          card.style.zIndex = String(100 - lvl);
        });
        dots.forEach((d, i) => d.setAttribute('data-on', i === active ? 'true' : 'false'));
      };
      place();
      let timer = 0;
      const tick = () => { active = (active + 1) % total; place(); };
      const start = () => { if (!timer && !noMotion) timer = window.setInterval(tick, 3000); };
      const stop = () => { if (timer) { clearInterval(timer); timer = 0; } };
      start();
      deck.addEventListener('pointerenter', stop);
      deck.addEventListener('pointerleave', start);
      cards.forEach((card, idx) =>
        card.addEventListener('click', () => {
          active = idx === active ? (active + 1) % total : idx;
          place();
        }),
      );
      dots.forEach((d, idx) =>
        d.addEventListener('click', () => { active = idx; place(); }),
      );
    });

    // Warm EVERY project screenshot into cache right after parse — long before
    // the user scrolls down — so decks are never blank on reveal. Images stay
    // loading="lazy" in markup (off-screen, browser keeps these warm fetches at
    // Low priority so the hero LCP is untouched), but the exact same resource
    // each <img> will request is pre-fetched here (sizes set first so the
    // responsive picker resolves the identical URL → guaranteed cache hit).
    const warmDeckImages = () => {
      document.querySelectorAll('.deck-card img').forEach((im) => {
        const pre = new Image();
        const sizes = im.getAttribute('sizes');
        const srcset = im.getAttribute('srcset');
        const src = im.getAttribute('src');
        if (sizes) pre.sizes = sizes;
        if (srcset) pre.srcset = srcset;
        if (src) pre.src = src;
      });
    };
    // Run after first paint (two frames) but well before window.load, giving
    // the most lead time without blocking the initial render.
    requestAnimationFrame(() => requestAnimationFrame(warmDeckImages));

    // Contact form → delivers straight to email in real time via Formsubmit
    // (no backend needed on a static site). First submission triggers a
    // one-time activation email to the inbox owner.
    const cform = document.getElementById('contact-form');
    if (cform) {
      const status = document.getElementById('cf-status');
      const submitBtn = document.getElementById('cf-submit');
      const submitLabel = submitBtn.querySelector('[data-label]');

      // Per-field validators → return '' when valid, else an error message.
      const validators = {
        'cf-name': (v) => (v.trim() ? '' : 'Please enter your name.'),
        'cf-email': (v) =>
          !v.trim()
            ? 'Please enter your email.'
            : /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim())
              ? ''
              : 'Please enter a valid email address.',
        'cf-message': (v) => (v.trim() ? '' : 'Please enter a short message.'),
      };
      const showFieldError = (id, msg) => {
        const field = document.getElementById(id);
        const err = document.getElementById('err-' + id.replace('cf-', ''));
        if (msg) {
          field.setAttribute('aria-invalid', 'true');
          err.textContent = msg;
          err.classList.remove('hidden');
        } else {
          field.removeAttribute('aria-invalid');
          err.textContent = '';
          err.classList.add('hidden');
        }
        return !msg;
      };
      // Live-clear an error once the user starts fixing that field.
      Object.keys(validators).forEach((id) => {
        const el = document.getElementById(id);
        el.addEventListener('input', () => {
          if (el.getAttribute('aria-invalid')) showFieldError(id, validators[id](el.value));
        });
      });

      const setStatus = (msg, ok) => {
        status.textContent = msg;
        status.style.color = ok === true ? '#9fe6b0' : ok === false ? '#ff9a8a' : '';
      };

      cform.addEventListener('submit', async (e) => {
        e.preventDefault();
        const honey = cform.querySelector('[name="_honey"]');
        if (honey && honey.value) return; // bot trap
        setStatus('', null);

        // Validate every field, surface inline errors, focus the first invalid.
        let firstInvalid = null;
        let allValid = true;
        Object.keys(validators).forEach((id) => {
          const el = document.getElementById(id);
          const ok = showFieldError(id, validators[id](el.value));
          if (!ok && !firstInvalid) firstInvalid = el;
          allValid = allValid && ok;
        });
        if (!allValid) {
          if (firstInvalid) firstInvalid.focus();
          return;
        }

        const original = submitLabel.textContent;
        submitBtn.disabled = true;
        submitLabel.textContent = 'Sending…';
        try {
          // ── Email delivery endpoint ──────────────────────────────────────
          // Provider: Formsubmit (no signup/key needed — it posts to your
          // address directly). To switch to Formspree instead, paste your
          // endpoint here, e.g.  https://formspree.io/f/XXXXXXXX
          // and keep the JSON body below unchanged.
          const ENDPOINT = 'https://formsubmit.co/ajax/darjidev9313@gmail.com';
          const res = await fetch(ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({
              name: document.getElementById('cf-name').value.trim(),
              email: document.getElementById('cf-email').value.trim(),
              message: document.getElementById('cf-message').value.trim(),
              _subject: 'New enquiry from your portfolio',
              _template: 'table',
            }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && String(data.success) === 'true') {
            cform.reset();
            setStatus("Thanks! I'll get back to you soon.", true);
          } else {
            setStatus('Something went wrong, please try again or email me directly.', false);
          }
        } catch (err) {
          setStatus('Something went wrong, please try again or email me directly.', false);
        } finally {
          submitBtn.disabled = false;
          submitLabel.textContent = original;
        }
      });
    }
  </script>
