        <!-- RIGHT: real-time contact form — delivers straight to email -->
        <div class="reveal reveal-delay-2">
          <form id="contact-form" class="space-y-5" novalidate>
            <div>
              <label for="cf-name" class="mb-2 block font-mono text-[11px] uppercase tracking-wide text-paper/65">Name</label>
              <input
                id="cf-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Your name"
                aria-describedby="err-name"
                class="w-full rounded-md border border-paper/15 bg-paper/[0.06] px-4 py-3.5 text-base text-paper outline-none transition placeholder:text-paper/35 focus:border-signal focus:bg-paper/[0.1] aria-[invalid=true]:border-red-400/70"
              />
              <p id="err-name" class="mt-1.5 hidden font-mono text-[11px] text-red-300"></p>
            </div>
            <div>
              <label for="cf-email" class="mb-2 block font-mono text-[11px] uppercase tracking-wide text-paper/65">Email</label>
              <input
                id="cf-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                inputmode="email"
                placeholder="you@company.com"
                aria-describedby="err-email"
                class="w-full rounded-md border border-paper/15 bg-paper/[0.06] px-4 py-3.5 text-base text-paper outline-none transition placeholder:text-paper/35 focus:border-signal focus:bg-paper/[0.1] aria-[invalid=true]:border-red-400/70"
              />
              <p id="err-email" class="mt-1.5 hidden font-mono text-[11px] text-red-300"></p>
            </div>
            <div>
              <label for="cf-message" class="mb-2 block font-mono text-[11px] uppercase tracking-wide text-paper/65">Project / Message</label>
              <textarea
                id="cf-message"
                name="message"
                rows="5"
                required
                placeholder="Tell me about your project…"
                aria-describedby="err-message"
                class="w-full resize-y rounded-md border border-paper/15 bg-paper/[0.06] px-4 py-3.5 text-base text-paper outline-none transition placeholder:text-paper/35 focus:border-signal focus:bg-paper/[0.1] aria-[invalid=true]:border-red-400/70"
              ></textarea>
              <p id="err-message" class="mt-1.5 hidden font-mono text-[11px] text-red-300"></p>
            </div>
            <!-- honeypot: hidden field bots fill, humans don't -->
            <input type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
            <button
              type="submit"
              id="cf-submit"
              class="group inline-flex w-full items-center justify-center gap-2 rounded-md bg-signal px-7 py-4 font-mono text-[13px] uppercase tracking-wide text-paper transition-transform hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:opacity-60"
            >
              <span data-label>Send message</span>
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </button>
            <p id="cf-status" role="status" aria-live="polite" class="min-h-[1.2em] font-mono text-[12px] text-paper/65"></p>
